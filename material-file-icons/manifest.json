{
  "schemaVersion": 1,
  "id": "delg.material-file-icons",
  "publisherId": "6a5302600325fb03204c8760",
  "publisher": {
    "displayName": "delg",
    "description": "Official DELG Plugins"
  },
  "name": "Material File Icons",
  "version": "1.2.0",
  "description": "Material Design SVG file icons for the explorer, covering more than 120 file extensions.",
  "entry": "dist/plugin.js",
  "icon": "media/icon.png",
  "images": ["media/overview.png"],
  "engines": {
    "delgIde": ">=0.3.0"
  },
  "capabilities": [
    "commands",
    "explorer-icons",
    "status",
    "status-bar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "delg.material-file-icons.showSummary",
        "title": "Material File Icons: Show Summary"
      }
    ],
    "menus": [
      {
        "command": "delg.material-file-icons.showSummary",
        "location": "commandPalette",
        "group": "appearance"
      },
      {
        "command": "delg.material-file-icons.showSummary",
        "location": "editor/context",
        "group": "appearance"
      }
    ],
    "keybindings": [
      {
        "command": "delg.material-file-icons.showSummary",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i"
      }
    ],
    "statusBarItems": [
      {
        "id": "delg.material-file-icons.status",
        "text": "Material Icons",
        "tooltip": "Registered Material explorer icons"
      }
    ]
  },
  "source": {
    "repository": "https://github.com/DELG-Software/DELG-Code-IDE-Plugins",
    "commit": "42e214c6cb7100e078b24f99766fe9e697cdda3d"
  }
}
